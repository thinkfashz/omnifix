# Omnifix environment example
# Copia este archivo a .env.local en desarrollo o configura estas variables en Vercel.
# No guardes valores reales de producción en GitHub.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=56930121625

# InsForge, requerido para datos persistentes
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
INSFORGE_API_KEY=

# Admin
ADMIN_SESSION_SECRET=
ADMIN_PASSWORD_PEPPER=
ADMIN_INITIAL_PASSWORD=
ADMIN_INIT_SECRET=
ADMIN_EMAIL=

# Mercado Pago, opcional hasta activar pagos reales
MERCADO_PAGO_ACCESS_TOKEN=
MERCADOPAGO_ACCESS_TOKEN=
MP_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADOPAGO_WEBHOOK_SECRET=
NEXT_PUBLIC_MP_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Mercado Libre, opcional
MERCADOLIBRE_ACCESS_TOKEN=
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_AUTH_DOMAIN=auth.mercadolibre.cl
ML_REDIRECT_URI=

# Shopify headless, opcional hasta activar tienda real
SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=2026-07
SHOPIFY_WEBHOOK_SECRET=

# Importadores y marketing, opcional
GOOGLE_CSE_CX=
GOOGLE_CSE_KEY=
JINA_API_KEY=
META_ACCESS_TOKEN=
META_API_VERSION=v25.0
META_AD_ACCOUNT_ID=
META_ACCOUNT_ID=

# Observabilidad, opcional
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
