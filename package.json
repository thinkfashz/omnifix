{
  "name": "omnifix",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "deploy:preflight": "node scripts/deploy-preflight.mjs",
    "deploy:verify": "npm run typecheck && npm run deploy:preflight && npm run build",
    "load:smoke": "node scripts/smoke-load.mjs",
    "audit:tenant": "node scripts/audit-multitenancy.mjs",
    "admin:set-password": "tsx scripts/set-admin-password.ts",
    "admin:enable-totp": "tsx scripts/enable-admin-totp.ts",
    "admin:disable-totp": "tsx scripts/disable-admin-totp.ts",
    "admin:generate-backup-codes": "tsx scripts/generate-admin-backup-codes.ts",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "deploy:cloudflare": "npm run cf:build && npm run cf:deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/model-viewer": "^4.2.0",
    "@insforge/sdk": "^1.2.5",
    "@monaco-editor/react": "^4.7.0",
    "@pascal-app/core": "^0.6.0",
    "@pascal-app/viewer": "^0.6.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.2",
    "@react-email/components": "^0.0.36",
    "@react-email/render": "^1.0.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@sentry/nextjs": "^10.51.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@use-gesture/react": "^10.3.1",
    "@vercel/analytics": "^2.0.1",
    "animejs": "^3.2.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^0.6.3",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "grapesjs": "^0.22.13",
    "gray-matter": "^4.0.3",
    "gsap": "^3.12.5",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.2",
    "isomorphic-dompurify": "^2.18.0",
    "jspdf": "^4.2.1",
    "lenis": "^1.3.23",
    "lucide-react": "^0.460.0",
    "marked": "^14.1.3",
    "mercadopago": "^2.4.0",
    "monaco-editor": "^0.52.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.11",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "resend": "^4.0.6",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.5",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "web-push": "^3.6.7",
    "zundo": "^2.3.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/animejs": "^3.1.13",
    "@types/node": "^22.19.3",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.14",
    "@types/three": "^0.184.1",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^3.2.4",
    "wrangler": "^4.106.0"
  }
